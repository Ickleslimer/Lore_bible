{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/conversation_segment.schema.json",
  "title": "ConversationSegment",
  "type": "object",
  "required": [
    "conversation_id",
    "dm_pair_id",
    "partner_id",
    "partner_label",
    "track",
    "topic_label",
    "topic_summary",
    "topic_shift_reason",
    "anchor_entities",
    "message_ids",
    "timestamp_start_utc",
    "timestamp_end_utc",
    "model_confidence",
    "source_coarse_window_id"
  ],
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "dm_pair_id": {
      "type": "string"
    },
    "partner_id": {
      "type": "string"
    },
    "partner_label": {
      "type": "string"
    },
    "participant_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "participant_labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "track": {
      "type": "string",
      "enum": [
        "lore",
        "meta",
        "both"
      ]
    },
    "topic_label": {
      "type": "string"
    },
    "topic_summary": {
      "type": "string"
    },
    "topic_shift_reason": {
      "type": "string"
    },
    "anchor_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevance_type": {
      "type": "string"
    },
    "relevance_rationale": {
      "type": "string"
    },
    "relevance_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "message_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "timestamp_start_utc": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp_end_utc": {
      "type": "string",
      "format": "date-time"
    },
    "message_count": {
      "type": "integer",
      "minimum": 1
    },
    "model_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_coarse_window_id": {
      "type": "string"
    },
    "source_model_window_id": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
