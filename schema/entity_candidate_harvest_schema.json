{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/entity_candidate_harvest.schema.json",
  "title": "EntityCandidateHarvest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "stage",
    "inputs",
    "policy",
    "summary",
    "candidates"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at_utc": { "type": "string" },
    "stage": { "type": "string" },
    "inputs": { "type": "object", "additionalProperties": true },
    "policy": { "type": "object", "additionalProperties": true },
    "summary": { "type": "object", "additionalProperties": true },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "candidate_name",
          "normalized_name_key",
          "surface_forms",
          "source_snippet_ids",
          "evidence_count",
          "first_seen_timestamp_utc",
          "last_seen_timestamp_utc",
          "sample_texts",
          "initial_proposed_entity_type",
          "type_evidence",
          "type_vote_totals",
          "type_conflicts",
          "known_entities_co_mentioned",
          "candidate_cooccurrences",
          "structured_alias_rename_snippet_ids",
          "signal_flags",
          "legacy_triage_hint"
        ],
        "properties": {
          "candidate_id": { "type": "string" },
          "candidate_name": { "type": "string" },
          "normalized_name_key": { "type": "string" },
          "surface_forms": { "type": "array", "items": { "type": "string" } },
          "source_snippet_ids": { "type": "array", "items": { "type": "string" } },
          "evidence_count": { "type": "integer", "minimum": 0 },
          "first_seen_timestamp_utc": { "type": "string" },
          "last_seen_timestamp_utc": { "type": "string" },
          "sample_texts": { "type": "array", "items": { "type": "string" } },
          "initial_proposed_entity_type": { "type": "string" },
          "proposed_entity_type": { "type": "string" },
          "type_evidence": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "type_vote_totals": { "type": "object", "additionalProperties": { "type": "number" } },
          "type_conflicts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "known_entities_co_mentioned": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "candidate_cooccurrences": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "structured_alias_rename_snippet_ids": { "type": "array", "items": { "type": "string" } },
          "signal_flags": { "type": "object", "additionalProperties": { "type": "boolean" } },
          "deterministic_signal_flags": { "type": "object", "additionalProperties": { "type": "boolean" } },
          "signal_details": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
          "model_annotation_status": { "type": "string" },
          "model_annotation": {
            "type": "object",
            "properties": {
              "candidate_name": { "type": "string" },
              "proposed_entity_type": { "type": "string" },
              "denotation_class": { "type": "string" },
              "recommended_track": { "type": "string" },
              "local_lore_prior": { "type": "number", "minimum": 0, "maximum": 1 },
              "external_reference_prior": { "type": "number", "minimum": 0, "maximum": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "canonical_name": { "type": ["string", "null"] },
              "alias_of": { "type": ["string", "null"] },
              "reasoning_summary": { "type": "string" },
              "human_review_question": { "type": "string" }
            },
            "additionalProperties": true
          },
          "model_denotation_class": { "type": "string" },
          "recommended_track": { "type": "string" },
          "local_lore_prior": { "type": "number", "minimum": 0, "maximum": 1 },
          "external_reference_prior": { "type": "number", "minimum": 0, "maximum": 1 },
          "model_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "model_reasoning_summary": { "type": "string" },
          "human_review_question": { "type": "string" },
          "model_suggested_canonical_name": { "type": "string" },
          "model_suggested_alias_of": { "type": "string" },
          "legacy_triage_hint": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
