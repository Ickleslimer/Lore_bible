{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/source_snippet.schema.json",
  "title": "SourceSnippet",
  "type": "object",
  "required": [
    "snippet_id",
    "thread_id",
    "partner_id",
    "partner_label",
    "message_ids",
    "timestamp_start_utc",
    "timestamp_end_utc",
    "speaker",
    "raw_text",
    "relevance_score",
    "relevance_reason",
    "candidate_entities",
    "knowledge_track",
    "candidate_topics",
    "sensitivity_flags",
    "provenance"
  ],
  "properties": {
    "snippet_id": {
      "type": "string"
    },
    "source_kind": {
      "type": "string"
    },
    "thread_id": {
      "type": "string"
    },
    "conversation_id": {
      "type": "string"
    },
    "dm_pair_id": {
      "type": "string"
    },
    "conversation_topic_label": {
      "type": "string"
    },
    "conversation_topic_summary": {
      "type": "string"
    },
    "conversation_track": {
      "type": "string",
      "enum": [
        "lore",
        "meta",
        "both",
        ""
      ]
    },
    "conversation_anchor_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversation_relevance_type": {
      "type": "string"
    },
    "conversation_relevance_rationale": {
      "type": "string"
    },
    "conversation_relevance_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "conversation_model_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "conversation_global_index": {
      "type": "integer",
      "minimum": 0
    },
    "conversation_patch_note_id": {
      "type": "string"
    },
    "conversation_patch_status": {
      "type": "string"
    },
    "conversation_patch_summary": {
      "type": "string"
    },
    "conversation_patch_lore_developments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversation_patch_meta_developments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversation_patch_open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversation_patch_possible_contradictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "partner_id": {
      "type": "string"
    },
    "partner_label": {
      "type": "string"
    },
    "message_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "timestamp_start_utc": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp_end_utc": {
      "type": "string",
      "format": "date-time"
    },
    "speaker": {
      "type": "string",
      "enum": [
        "you",
        "partner",
        "unknown"
      ]
    },
    "raw_text": {
      "type": "string"
    },
    "display_text_normalized": {
      "type": "string"
    },
    "patch_item_type": {
      "type": "string"
    },
    "patch_item_index": {
      "type": "integer",
      "minimum": 0
    },
    "patch_item_text": {
      "type": "string"
    },
    "patch_development_type": {
      "type": "string"
    },
    "patch_update_type": {
      "type": "string"
    },
    "patch_relationship_type": {
      "type": "string"
    },
    "patch_candidate_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "patch_supporting_message_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_conflicts_with_prior_patch_note_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "relevance_reason": {
      "type": "string"
    },
    "candidate_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knowledge_track": {
      "type": "string",
      "enum": [
        "lore",
        "meta",
        "unknown"
      ]
    },
    "candidate_topics": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "entity",
          "event",
          "mechanic",
          "theme",
          "quest",
          "marketing",
          "production",
          "go_to_market",
          "audience"
        ]
      }
    },
    "sensitivity_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "json_path",
        "export_batch",
        "parser_version",
        "content_hash"
      ],
      "properties": {
        "json_path": {
          "type": "string"
        },
        "export_batch": {
          "type": "string"
        },
        "parser_version": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
