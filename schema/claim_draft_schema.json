{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/claim_draft.schema.json",
  "title": "ClaimDraft",
  "type": "object",
  "required": [
    "claim_id",
    "target_entity_id",
    "target_card_id",
    "target_entity_name",
    "knowledge_track",
    "claim_text",
    "claim_type",
    "source_snippet_ids",
    "confidence",
    "status",
    "contradiction_notes",
    "created_at_utc"
  ],
  "properties": {
    "claim_id": { "type": "string" },
    "target_entity_id": { "type": "string" },
    "target_card_id": { "type": "string" },
    "target_entity_name": { "type": "string" },
    "knowledge_track": { "type": "string", "enum": ["lore", "meta"] },
    "claim_text": { "type": "string" },
    "claim_type": {
      "type": "string",
      "enum": ["background", "role", "relationship", "timeline", "theme", "alias", "inspiration", "open_question", "other", "lore_fact"]
    },
    "alias_text": { "type": "string" },
    "source_snippet_ids": { "type": "array", "items": { "type": "string" } },
    "thematic_tags": { "type": "array", "items": { "type": "string" } },
    "proposed_relationship_hints": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["draft", "accepted", "rejected", "defer", "needs_more_context"] },
    "contradiction_notes": { "type": "string" },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "normalized_claim_text": { "type": "string" },
    "support_warnings": { "type": "array", "items": { "type": "string" } }
  },
  "not": {
    "required": ["proposed_summary_append"]
  },
  "additionalProperties": false
}
