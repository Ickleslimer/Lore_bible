{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/conversation_entity_proposal.schema.json",
  "title": "ConversationEntityProposal",
  "type": "object",
  "required": [
    "proposal_id",
    "candidate_name",
    "normalized_name_key",
    "proposed_entity_type",
    "source_snippet_ids",
    "first_seen_timestamp_utc",
    "last_seen_timestamp_utc",
    "evidence_count",
    "sample_texts",
    "confidence",
    "review_status"
  ],
  "properties": {
    "proposal_id": { "type": "string" },
    "candidate_name": { "type": "string" },
    "normalized_name_key": { "type": "string" },
    "initial_proposed_entity_type": {
      "type": "string",
      "enum": ["character", "faction", "organization", "location", "quest", "event", "timeline_node", "theme", "term"]
    },
    "proposed_entity_type": {
      "type": "string",
      "enum": ["character", "faction", "organization", "location", "quest", "event", "timeline_node", "theme", "term"]
    },
    "type_evidence": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "type_vote_totals": { "type": "object", "additionalProperties": { "type": "number" } },
    "type_conflicts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "type_reconsidered": { "type": "boolean" },
    "type_review_notes": { "type": "string" },
    "knowledge_tracks": { "type": "array", "items": { "type": "string" } },
    "knowledge_track_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "candidate_topics": { "type": "array", "items": { "type": "string" } },
    "source_kinds": { "type": "array", "items": { "type": "string" } },
    "source_kind_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "patch_item_types": { "type": "array", "items": { "type": "string" } },
    "patch_item_type_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "patch_update_types": { "type": "array", "items": { "type": "string" } },
    "patch_update_type_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "patch_relationship_types": { "type": "array", "items": { "type": "string" } },
    "patch_relationship_type_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "source_snippet_ids": { "type": "array", "items": { "type": "string" } },
    "first_seen_timestamp_utc": { "type": "string" },
    "last_seen_timestamp_utc": { "type": "string" },
    "evidence_count": { "type": "integer", "minimum": 0 },
    "sample_texts": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "deferred", "needs_more_context"]
    },
    "proposal_reason": { "type": "string" },
    "triage_status": { "type": "string" },
    "triage_reason": { "type": "string" },
    "review_priority": { "type": "string" },
    "latest_decision": { "type": "object" }
  },
  "additionalProperties": true
}
