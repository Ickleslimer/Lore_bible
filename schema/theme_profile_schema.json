{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theriac/theme_profile.schema.json",
  "title": "ThemeProfile",
  "type": "object",
  "required": ["schema_version", "policy", "themes"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at_utc": { "type": ["string", "null"] },
    "policy": {
      "type": "object",
      "properties": {
        "canon_gate": { "type": "string" },
        "theme_learning_scope": { "type": "string" },
        "transitive_thematic_learning_not_transitive_canon": { "type": "boolean" },
        "theme_match_is_not_promotion_rule": { "type": "boolean" },
        "theme_provenance_required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "theme_id",
          "label",
          "theme_type",
          "status",
          "confidence",
          "canon_relevance",
          "description",
          "evidence_entities",
          "evidence_claim_ids",
          "evidence_snippet_ids",
          "positive_indicators",
          "negative_indicators",
          "related_themes",
          "disambiguation_notes",
          "last_updated"
        ],
        "properties": {
          "theme_id": { "type": "string" },
          "label": { "type": "string" },
          "theme_type": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["candidate", "active", "deprecated", "meta_only", "rejected"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "canon_relevance": { "type": "string" },
          "description": { "type": "string" },
          "evidence_entities": { "type": "array", "items": { "type": "string" } },
          "evidence_claim_ids": { "type": "array", "items": { "type": "string" } },
          "evidence_snippet_ids": { "type": "array", "items": { "type": "string" } },
          "positive_indicators": { "type": "array", "items": { "type": "string" } },
          "negative_indicators": { "type": "array", "items": { "type": "string" } },
          "related_themes": { "type": "array", "items": { "type": "string" } },
          "disambiguation_notes": { "type": "array", "items": { "type": "string" } },
          "pattern_notes": { "type": "array", "items": { "type": "string" } },
          "provenance_summary": { "type": "string" },
          "created_at_utc": { "type": "string" },
          "last_updated": { "type": "string" },
          "last_update_action": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "theme_update_log": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
  },
  "additionalProperties": true
}
